# This directory IS the snakemake work dir. Only the committed source inputs
# below are tracked. setup_integration_test.py downloads the FASTA + raw files;
# snakemake generates everything else (dataset.csv, out-DIANN_*, temp-DIANN_*,
# logs/, qc_result/, step_*.sh, Result_*.zip, outputs.yml).
/*
!/.gitignore
!/setup_integration_test.py
!/run.sh
!/tree.txt
!/params.yml
!/inputs.yml
!/input/
/input/*
!/input/order.fasta
!/input/raw/
/input/raw/*
!/input/raw/dataset.parquet
