# This directory IS the snakemake work dir. Only the committed inputs the
# workflow actually needs are tracked: params.yml + dataset.csv (the same files
# bfabric-app-runner provides). setup_integration_test.py downloads the FASTA +
# raw files; snakemake generates everything else (out-DIANN_*, temp-DIANN_*,
# logs/, qc_result/, step_*.sh, Result_*.zip, outputs.yml).
/*
!/.gitignore
!/setup_integration_test.py
!/run.sh
!/tree.txt
!/params.yml
!/dataset.csv
