# DIA-NN 2.5+ on Debian with .NET 8 (required for Thermo RawFileReader)
#
# Starting from 2.5.0 DIA-NN ships a managed Thermo .raw reader (RawWrapper.dll
# + ThermoFisher.CommonCore.*.dll) which requires the .NET 8 runtime. Building
# on Debian 12 follows the recommendation in the upstream release notes and
# mirrors the Dockerfile bundled inside the 2.5.0 zip.
FROM debian:12

ARG DIANN_VERSION=2.5.0
ARG DIANN_URL="https://github.com/vdemichev/DiaNN/releases/download/2.0/DIA-NN-${DIANN_VERSION}-Academia-Linux.zip"

LABEL org.opencontainers.image.version="${DIANN_VERSION}"
LABEL org.opencontainers.image.description="DIA-NN ${DIANN_VERSION} with native Thermo .raw support (.NET 8)"
LABEL org.opencontainers.image.source="https://github.com/vdemichev/DiaNN"

ENV DEBIAN_FRONTEND=noninteractive

# Locales (DIA-NN expects a UTF-8 locale)
RUN apt-get update && \
    apt-get install -y --no-install-recommends locales ca-certificates wget unzip libgomp1 && \
    sed -i -e 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen && \
    dpkg-reconfigure --frontend=noninteractive locales && \
    rm -rf /var/lib/apt/lists/*

# .NET SDK 8.0 from Microsoft's Debian 12 repo (needed for Thermo RawFileReader)
RUN wget -q https://packages.microsoft.com/config/debian/12/packages-microsoft-prod.deb -O /tmp/ms.deb && \
    dpkg -i /tmp/ms.deb && rm /tmp/ms.deb && \
    apt-get update && \
    apt-get install -y --no-install-recommends dotnet-sdk-8.0 && \
    rm -rf /var/lib/apt/lists/*

# Install DIA-NN. We keep the binary alongside its dlls and expose it via a
# wrapper so that .NET assembly resolution (relative to the executable) works.
RUN mkdir -p /opt && \
    wget -O /tmp/diann.zip "$DIANN_URL" && \
    unzip -q /tmp/diann.zip -d /opt && \
    rm /tmp/diann.zip && \
    DIANN_DIR=$(find /opt -maxdepth 1 -type d -name 'diann-*' -print -quit) && \
    chmod -R 755 "$DIANN_DIR" && \
    chmod +x "$DIANN_DIR/diann-linux" && \
    printf '#!/bin/sh\nexec %s/diann-linux "$@"\n' "$DIANN_DIR" > /usr/local/bin/diann-linux && \
    chmod +x /usr/local/bin/diann-linux

ENV LC_ALL=C.UTF-8 LANG=en_US.UTF-8
WORKDIR /work
ENTRYPOINT ["diann-linux"]

# =============================================================================
# Build:
#   docker build --platform linux/amd64 \
#     -f docker/Dockerfile.diann_thermofilereader -t diann:2.5.0-thermo .
#
# Run:
#   docker run --rm --platform linux/amd64 -v $(pwd):/work diann:2.5.0-thermo --help
#   docker run --rm -v $(pwd):/work diann:2.5.0-thermo \
#     --f data.raw --fasta proteins.fasta --out report.parquet
# =============================================================================
